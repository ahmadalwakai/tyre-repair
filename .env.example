# ───── Database ─────
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ───── Site ─────
NEXT_PUBLIC_SITE_URL=https://tyrerepair.uk
NEXT_PUBLIC_BUSINESS_PHONE_E164=+441412660690
NEXT_PUBLIC_BUSINESS_PHONE_DISPLAY=0141 266 0690
NEXT_PUBLIC_BUSINESS_WHATSAPP=447423262955
NEXT_PUBLIC_BUSINESS_ADDRESS_LINE1=Unit 1, 10 Gateside Street
NEXT_PUBLIC_BUSINESS_ADDRESS_CITY=Glasgow
NEXT_PUBLIC_BUSINESS_POSTCODE=G31 1PD
NEXT_PUBLIC_BUSINESS_LAT=55.8588
NEXT_PUBLIC_BUSINESS_LNG=-4.2200

# ───── External APIs (filled phase-by-phase) ─────
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
MAPBOX_ACCESS_TOKEN=
DVLA_VES_API_KEY=
RESEND_API_KEY=
# Use onboarding@resend.dev in dev (sandbox sender, only delivers to the
# Resend account-owner email). For production, verify your domain at
# https://resend.com/domains and use e.g. bookings@tyrerepair.uk
RESEND_FROM_EMAIL=onboarding@resend.dev
WEATHER_API_KEY=
WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ───── Location capture (Phase 4) ─────
LOCATION_CAPTURE_SECRET=

# ───── Pusher (realtime) ─────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ───── Twilio (SMS) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_FROM_PHONE=

# ───── Admin ─────
ADMIN_JWT_SECRET=
ADMIN_EMAIL=
SEED_ADMIN_EMAIL=admin@tyrerepair.uk
SEED_ADMIN_PASSWORD=
ADMIN_SESSION_TTL_DAYS=30
ADMIN_PASSWORD_RESET_TTL_MINUTES=30
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ───── Admin push notifications (Phase 8) ─────
# Optional access token for the Expo Push API. Required for higher rate limits / enhanced security checks.
EXPO_ACCESS_TOKEN=
# Expo project ID (visible in app.json `extra.eas.projectId`). Used as fallback in the mobile app.
EXPO_PROJECT_ID=
EXPO_PUSH_ENABLED=true
ADMIN_NOTIFICATION_DEFAULT_SOUND=admin_alert.mp3

# ───── Business HQ ─────
BUSINESS_HQ_LAT=55.858876
BUSINESS_HQ_LNG=-4.218064
BUSINESS_HQ_ADDRESS=Unit 1, 10 Gateside Street, Glasgow G31 1PD
